  "description": "Engineering reasoning capture, distillation, and personalization",
  "version": "0.1.0",
  "transport": {
    "type": "stdio",
    "command": "npx",
    "args": ["unfade", "mcp"]
  },
  "capabilities": {
    "tools": true,
    "resources": true,
    "prompts": true
  },
