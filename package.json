{
  "name": "unfade",
  "version": "0.1.0",
  "description": "Passively capture engineering reasoning from developer workflows. Your AI tools remember how you think.",
  "type": "module",
  "bin": {
    "unfade": "./dist/cli.mjs"
  },
  "files": [
    "dist/",
    "skills/",
    "server.json"
  ],
  "scripts": {
    "build:daemon": "bash scripts/build-daemon.sh",
    "build:ui": "vite build",
    "build": "pnpm build:ui && tsdown",
    "dev": "tsx watch src/entrypoints/cli.ts",
    "dev:ui": "vite",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "unfade",
    "reasoning",
    "mcp",
    "ai",
    "developer-tools",
    "distill",
    "capture",
    "thinking-graph",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unerr-ai/unfade.git"
  },
  "homepage": "https://github.com/unerr-ai/unfade#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@unfade/daemon-darwin-arm64": "workspace:*",
    "@unfade/daemon-darwin-x64": "workspace:*",
    "@unfade/daemon-linux-arm64": "workspace:*",
    "@unfade/daemon-linux-x64": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@resvg/resvg-js",
      "better-sqlite3",
      "cozo-node",
      "esbuild"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/openai": "^3.0.53",
    "@clack/prompts": "^1.2.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@duckdb/node-api": "1.5.2-r.1",
    "@hono/node-server": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/cli": "^4.2.4",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-virtual": "^3.13.24",
    "ai": "^6.0.162",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.0",
    "cozo-node": "^0.7.6",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.14",
    "lucide-react": "^1.9.0",
    "node-notifier": "^10.0.1",
    "ollama-ai-provider": "^1.2.0",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "piscina": "^5.1.4",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "satori": "^0.26.0",
    "simple-statistics": "^7.8.9",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/node-notifier": "^8.0.5",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  }
}
