{
  "name": "unfade",
  "version": "0.1.0",
  "description": "Passively capture engineering reasoning from developer workflows. Your AI tools remember how you think.",
  "type": "module",
  "bin": {
    "unfade": "./dist/cli.mjs"
  },
  "files": [
    "dist/",
    "skills/",
    "server.json"
  ],
  "scripts": {
    "build:daemon": "bash scripts/build-daemon.sh",
    "build": "tsdown",
    "dev": "tsx watch src/entrypoints/cli.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "unfade",
    "reasoning",
    "mcp",
    "ai",
    "developer-tools",
    "distill",
    "capture",
    "thinking-graph",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unerr-ai/unfade.git"
  },
  "homepage": "https://github.com/unerr-ai/unfade#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "optionalDependencies": {
    "@unfade/daemon-darwin-arm64": "workspace:*",
    "@unfade/daemon-darwin-x64": "workspace:*",
    "@unfade/daemon-linux-arm64": "workspace:*",
    "@unfade/daemon-linux-x64": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@resvg/resvg-js",
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/openai": "^3.0.53",
    "@clack/prompts": "^1.2.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-js": "^2.6.2",
    "ai": "^6.0.162",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "node-notifier": "^10.0.1",
    "ollama-ai-provider": "^1.2.0",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "satori": "^0.26.0",
    "simple-statistics": "^7.8.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.21.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
